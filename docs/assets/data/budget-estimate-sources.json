  "sourceGroups": [
    {
      "id": "lodging",
      "label": { "en": "Lodging", "ja": "宿泊" },
      "body": {
        "en": "Nightly room estimates come from current Expedia quotes for practical stays in Osaka, Hakone, Fujikawaguchiko, and Shibuya. USD room quotes are converted to yen with the ECB rate above, then split across travelers using one room per two travelers.",
        "ja": "宿泊は大阪、箱根、富士河口湖、渋谷の現行Expedia価格を使い、上記のECB為替で円換算したうえで、2人で1室を基本に人数へ按分しています。"
      },
      "links": [
        {
          "label": { "en": "Tokyu Stay Osaka Honmachi", "ja": "Tokyu Stay Osaka Honmachi" },
          "url": "https://www.expedia.com/Osaka-Hotels-Tokyu-Stay-Osaka-Honmachi.h39286570.Hotel-Information"
        },
        {
          "label": { "en": "Hakone Pax Yoshino", "ja": "Hakone Pax Yoshino" },
