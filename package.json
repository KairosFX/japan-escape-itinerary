{
  "name": "itinerary",
  "private": true,
  "scripts": {
    "build:section-content": "node scripts/build-section-content.js",
    "build:css": "cleancss -o docs/style.min.css docs/style.css",
    "build:route-css": "cleancss -o docs/route.min.css docs/route.css",
    "build:js": "terser docs/script.js -c -m -o docs/script.min.js",
    "build:route-data": "terser docs/route-content.js -c -m -o docs/route-content.min.js",
    "build:budget-ui": "terser docs/budget-ui.js -c -m -o docs/budget-ui.min.js",
    "build:budget-data": "terser docs/budget-content.js -c -m -o docs/budget-content.min.js",
    "build:essentials-data": "terser docs/essentials-content.js -c -m -o docs/essentials-content.min.js",
    "build:assets": "node scripts/version-app-assets.js",
    "build:service-worker": "node scripts/build-service-worker.js",
    "build:html": "node scripts/inline-css.js",
    "build:offline-snapshot": "node scripts/build-offline-snapshot.js",
    "build": "npm run build:section-content && npm run build:css && npm run build:route-css && npm run build:js && npm run build:route-data && npm run build:budget-ui && npm run build:budget-data && npm run build:essentials-data && npm run build:assets && npm run build:service-worker && npm run build:html && npm run build:offline-snapshot",
    "perf": "node scripts/run-perf.js"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "terser": "^5.46.1"
  }
}
